# Copy this file to ".env" and fill in your key to enable the Death AI coach.
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Optional: Groq fallback (free tier). If a Claude call fails, the same turn is
# retried on Groq automatically; with only this key set, Groq is used directly.
# Get a free key at https://console.groq.com/
GROQ_API_KEY=
# Groq model to use (defaults to llama-3.3-70b-versatile when left empty):
MBD_GROQ_MODEL=

# Optional overrides:
# MBD_COACH_MODEL=claude-opus-4-8   # or claude-sonnet-4-6 for lower cost/latency
# MBD_API_PORT=8787

# ---- User accounts (optional locally, required for accounts on Vercel) ----

# Signs session cookies. Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# "Continue with Google" (optional). Create an OAuth client (type: Web) at
# https://console.cloud.google.com/apis/credentials and add BOTH redirect URIs:
#   http://localhost:5174/api/auth/google/callback   (local dev)
#   https://YOUR-APP.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database. Locally leave empty (accounts persist to .data/ JSON files).
# On Vercel: create Storage -> Postgres/Neon and connect it to the project —
# that injects POSTGRES_URL automatically; nothing to paste here.
# POSTGRES_URL=
