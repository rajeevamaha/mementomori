# Copy this file to ".env" and fill in your key to enable the Death AI coach.
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# The coach tries providers in this order and rolls to the next on any failure
# (rate limit, outage, no credits): ANTHROPIC -> GROQ -> OPENROUTER. Any subset
# works; set at least one. If ALL fail, Death still replies in-character.

# Groq fallback (free tier). Get a free key at https://console.groq.com/
GROQ_API_KEY=
# Groq model (defaults to llama-3.3-70b-versatile when empty):
MBD_GROQ_MODEL=

# OpenRouter fallback — aggregates many providers, near-free open models, a
# rotating free tier. Great for a public demo. https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OpenRouter model (defaults to meta-llama/llama-3.3-70b-instruct when empty;
# for pennies, try meta-llama/llama-3.1-8b-instruct):
MBD_OPENROUTER_MODEL=

# Optional overrides:
# MBD_COACH_MODEL=claude-opus-4-8   # or claude-sonnet-4-6 for lower cost/latency
# MBD_API_PORT=8787
# MBD_PUBLIC_URL=https://thefinalcalendar.com   # sent to OpenRouter as HTTP-Referer

# ---- Rate limits (protect your keys/budget on a public demo) ----
# Per rolling 24h. Guests are counted by IP, signed-in users by account.
# MBD_RATE_GUEST_PER_DAY=12
# MBD_RATE_USER_PER_DAY=120

# ---- User accounts (optional locally, required for accounts on Vercel) ----

# Signs session cookies. Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# "Continue with Google" (optional). Create an OAuth client (type: Web) at
# https://console.cloud.google.com/apis/credentials and add BOTH redirect URIs:
#   http://localhost:5174/api/auth/google/callback   (local dev)
#   https://YOUR-APP.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database. Locally leave empty (accounts persist to .data/ JSON files).
# On Vercel: create Storage -> Postgres/Neon and connect it to the project —
# that injects POSTGRES_URL automatically; nothing to paste here.
# POSTGRES_URL=
